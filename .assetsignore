# Wrangler가 Static Assets로 업로드할 때 제외할 파일들
# .gitignore 문법과 동일

# 버전 관리 / 설정
.git/
.github/
.gitignore
.assetsignore

# Wrangler 관련
wrangler.toml
.wrangler/

# 문서 / 에이전트 지침 (배포 필요 없음)
CLAUDE.md
README.md
*.md

# 스크립트
deploy.bat
*.sh

# 에디터 / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Node (만약 생긴다면)
node_modules/
package*.json
