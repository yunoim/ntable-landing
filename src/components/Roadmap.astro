---
import type { ContentFor } from '../data/config';
type Props = { data: ContentFor<'roadmap'> };
const { data } = Astro.props;
---

<section id="roadmap">
  <div class="section-tag reveal">{data.section_tag}</div>
  <h2 class="section-title reveal">{data.title}</h2>
  <div class="phase-list reveal">
    {data.phases.map((p) => (
      <div class={`phase-item${p.state === 'active' ? ' active' : ''}`}>
        <div class="phase-label">
          <span>{p.label_has_dot && <span class="phase-dot"></span>}{p.label}</span>
          <strong>{p.phase_num}</strong>
        </div>
        <div class="roadmap-content">
          <div class="roadmap-content-title">{p.title}</div>
          <div class="roadmap-content-body">{p.body}</div>
          <div class="roadmap-tags">
            {p.tags.map((t) => <span class="roadmap-tag">{t}</span>)}
          </div>
          {p.note && <div class="phase-note">{p.note}</div>}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .phase-list {
    display: flex;
    flex-direction: column;
    margin-top: 56px;
  }
  .phase-item {
    display: grid;
    grid-template-columns: 150px 1fr;
    gap: 36px;
    padding: 36px 0;
    border-bottom: 1px solid var(--border-subtle);
    align-items: start;
  }
  .phase-item:last-child { border-bottom: none; }

  .phase-label {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    text-transform: uppercase;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-top: 4px;
  }
  .phase-label :global(strong) {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 600;
    color: var(--gold);
    text-transform: none;
    letter-spacing: 0;
  }
  .phase-item.active .phase-label { color: var(--gold-bright); }

  .phase-dot {
    display: inline-block;
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--gold);
    margin-right: 6px;
    vertical-align: middle;
    animation: pulse 2s ease-in-out infinite;
  }

  .roadmap-content-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 21px;
    font-weight: 600;
    color: var(--text-bright);
    margin-bottom: 10px;
    line-height: 1.3;
  }
  .roadmap-content-body {
    font-size: 14px;
    font-weight: 300;
    color: var(--text-highlight);
    line-height: 1.85;
    margin-bottom: 16px;
  }
  .roadmap-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .roadmap-tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.05em;
    padding: 4px 12px;
    border: 1px solid var(--border-strong);
    border-radius: 40px;
    color: var(--gold);
    background: rgba(232,184,75,0.18);
  }
  .phase-note {
    font-size: 11px;
    color: #9aa0ac;
    margin-top: 8px;
    letter-spacing: 0.02em;
  }

  .phase-item.active {
    background: linear-gradient(90deg, rgba(212,168,67,0.08), transparent 70%);
    border-left: 2px solid var(--gold);
    padding-left: 24px;
    margin-left: -26px;
    border-radius: 0 12px 12px 0;
  }
  .phase-item.active .roadmap-content-title { color: var(--gold-bright); }

  @media (max-width: 960px) {
    .phase-item { grid-template-columns: 1fr; gap: 10px; }
    .phase-item.active { margin-left: 0; padding-left: 18px; }
  }
</style>
