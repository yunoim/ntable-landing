---
import type { ContentFor } from '../data/config';
type Props = { data: ContentFor<'stats'> };
const { data } = Astro.props;
---

<div id="stats" data-api={data.live_widget.api} data-refresh-ms={data.live_widget.refresh_ms} data-meta-refresh-ms={data.live_widget.meta_refresh_ms}>
  <div class="stats-inner reveal">
    <div class="stats-badge">
      <span class="stats-badge-dot"></span>
      {data.badge}
    </div>
    <div>
      <div class="cumulative-stats" id="cumulativeStats" aria-live="polite" data-template={data.live_widget.cumulative_template_html}>
        <Fragment set:html={data.live_widget.cumulative_template_html.replace('{people}', '<strong id="cumPeople">—</strong>').replace('{rooms}', '<strong id="cumRooms">—</strong>')} />
      </div>
      <span class="live-stats-meta" id="liveStatsMeta"></span>
    </div>
    <div class="stats-grid">
      {data.cards.map((c) => (
        <div class="stat-item">
          <div class="stat-number">{c.number}</div>
          <div class="stat-label"><Fragment set:html={c.label_html} /></div>
        </div>
      ))}
    </div>
  </div>
</div>

<script>
  // Live stats — polls #stats[data-api] every refresh_ms, updates Stats widget
  // + Hero live badge. Zero-state suppresses widget; error-state falls back
  // to #heroLive placeholder text.
  (function () {
    const statsEl = document.getElementById('stats');
    if (!statsEl) return;
    const api = statsEl.dataset.api || '';
    const refreshMs = Number(statsEl.dataset.refreshMs || 30000);
    const metaRefreshMs = Number(statsEl.dataset.metaRefreshMs || 5000);

    const metaEl = document.getElementById('liveStatsMeta');
    const hero = document.getElementById('heroLive');
    const heroText = document.getElementById('heroLiveText');
    const cumRoomsEl = document.getElementById('cumRooms');
    const cumPeopleEl = document.getElementById('cumPeople');
    const cumWrap = document.getElementById('cumulativeStats');

    if (!hero) return;

    const state: { cumRooms: number; cumPeople: number; lastFetchAt: number | null } = {
      cumRooms: 0, cumPeople: 0, lastFetchAt: null,
    };

    const emptyHtml = hero?.dataset.emptyHtml || '';
    const errorText = hero?.dataset.errorText || '';

    function animateCount(el: HTMLElement | null, from: number, to: number, dur = 800) {
      if (!el) return;
      if (from === to) { el.textContent = String(to); return; }
      const start = performance.now();
      function step(now: number) {
        const t = Math.min((now - start) / dur, 1);
        const eased = 1 - Math.pow(1 - t, 3);
        if (el) el.textContent = String(Math.round(from + (to - from) * eased));
        if (t < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
      el.classList.add('flash');
      setTimeout(() => el.classList.remove('flash'), 700);
    }

    function formatRelative(ts: number | null) {
      if (!ts) return '';
      const diff = Math.max(0, Math.round((Date.now() - ts) / 1000));
      if (diff < 5) return '방금 업데이트';
      if (diff < 60) return `${diff}초 전 업데이트`;
      const m = Math.floor(diff / 60);
      return `${m}분 전 업데이트`;
    }

    function renderHeroEmpty() {
      // Hero badge stays in "empty" invitation state — no live numbers.
      // Live room/participant counts intentionally not surfaced; only
      // cumulative totals render in this section (see tick()).
      if (hero && heroText) {
        heroText.innerHTML = emptyHtml;
        hero.dataset.state = 'empty';
      }
    }

    function renderMeta() {
      if (metaEl) metaEl.textContent = formatRelative(state.lastFetchAt);
    }

    async function tick() {
      try {
        const res = await fetch(api, { cache: 'no-store' });
        if (!res.ok) throw new Error('stats not ok');
        const data = await res.json();
        const cumRooms = Number(data.total_rooms ?? 0);
        const cumPeople = Number(data.unique_people ?? 0);
        state.lastFetchAt = Date.now();
        renderHeroEmpty();
        if (cumRooms === 0 && cumPeople === 0) {
          if (cumWrap) (cumWrap as HTMLElement).style.display = 'none';
        } else {
          if (cumWrap) (cumWrap as HTMLElement).style.display = '';
          if (cumRoomsEl) animateCount(cumRoomsEl, state.cumRooms, cumRooms);
          if (cumPeopleEl) animateCount(cumPeopleEl, state.cumPeople, cumPeople);
        }
        state.cumRooms = cumRooms;
        state.cumPeople = cumPeople;
        renderMeta();
      } catch {
        if (hero) hero.dataset.state = 'empty';
        if (heroText) heroText.textContent = errorText;
        if (cumRoomsEl) cumRoomsEl.textContent = '—';
        if (cumPeopleEl) cumPeopleEl.textContent = '—';
      }
    }

    tick();
    setInterval(tick, refreshMs);
    setInterval(renderMeta, metaRefreshMs);
  })();
</script>

<style>
  /* 2026-05-13 Phase A: 라이트 모드 prototype (사용자 letsur.ai 참고 개편 결정).
     scoped 변수로만 처리 — tokens.css 안 건드림. Phase B에서 토큰 통일 예정.
     색상 정책: 배경 순백 / 본문 navy / 보조 차콜 / gold·navy 포인트는 브랜드 자산으로 유지. */
  #stats {
    --stats-bg: #ffffff;
    --stats-ink: #1a2b4d;
    --stats-ink-soft: #4a5568;
    --stats-ink-muted: #94a3b8;
    --stats-line: #e5e7eb;

    padding: 80px 32px;
    border-top: 1px solid var(--stats-line);
    border-bottom: 1px solid var(--stats-line);
    background: var(--stats-bg);
    color: var(--stats-ink);
  }
  .stats-inner {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }
  .stats-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 18px;
    border: 1px solid var(--gold);
    background: transparent;
    border-radius: 40px;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--stats-ink);
    margin-bottom: 36px;
  }
  .stats-badge-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--gold);
    box-shadow: 0 0 8px rgba(212,168,67,0.45);
    animation: pulse 2s ease-in-out infinite;
  }

  .live-stats-meta {
    display: block;
    margin-top: 8px;
    text-align: center;
    font-size: 10.5px;
    color: var(--stats-ink-muted);
    letter-spacing: 0.04em;
  }

  .cumulative-stats {
    display: block;
    margin-top: 14px;
    text-align: center;
    font-size: 13px;
    color: var(--stats-ink-soft);
    font-weight: 400;
    letter-spacing: 0.02em;
  }
  .cumulative-stats :global(strong) {
    color: var(--gold);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    transition: color var(--transition);
  }
  .cumulative-stats :global(strong.flash) { color: var(--stats-ink); }

  .stats-grid {
    max-width: 1100px;
    margin: 56px auto 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
  }
  .stats-grid > * { min-width: 0; }
  .stat-item { text-align: center; }
  .stat-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 48px;
    font-weight: 700;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 10px;
    font-variant-numeric: lining-nums tabular-nums;
    font-feature-settings: 'lnum' 1, 'tnum' 1;
  }
  .stat-label {
    font-size: 13px;
    font-weight: 400;
    color: var(--stats-ink-soft);
    line-height: 1.55;
  }

  @media (max-width: 960px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 580px) {
    #stats { padding: 56px 20px; }
  }
</style>
