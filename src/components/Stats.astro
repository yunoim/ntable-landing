---
import type { ContentFor } from '../data/config';
type Props = { data: ContentFor<'stats'> };
const { data } = Astro.props;
---

<div id="stats" data-api={data.live_widget.api} data-refresh-ms={data.live_widget.refresh_ms} data-meta-refresh-ms={data.live_widget.meta_refresh_ms}>
  <div class="stats-inner reveal">
    <div class="stats-badge">
      <span class="stats-badge-dot"></span>
      {data.badge}
    </div>
    <div>
      <div class="live-stats" id="liveStats" data-state="empty" aria-live="polite">
        <div class="live-stats-item">
          <span class="live-stats-num" id="liveRooms">—</span>
          <span class="live-stats-label">{data.live_widget.rooms_label}</span>
        </div>
        <div class="live-stats-sep"></div>
        <div class="live-stats-item">
          <span class="live-stats-num" id="liveParticipants">—</span>
          <span class="live-stats-label">{data.live_widget.people_label}</span>
        </div>
      </div>
      <div class="cumulative-stats" id="cumulativeStats" aria-live="polite" data-template={data.live_widget.cumulative_template_html}>
        <Fragment set:html={data.live_widget.cumulative_template_html.replace('{people}', '<strong id="cumPeople">—</strong>').replace('{rooms}', '<strong id="cumRooms">—</strong>')} />
      </div>
      <span class="live-stats-meta" id="liveStatsMeta"></span>
    </div>
    <div class="stats-grid">
      {data.cards.map((c) => (
        <div class="stat-item">
          <div class="stat-number">{c.number}</div>
          <div class="stat-label"><Fragment set:html={c.label_html} /></div>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  #stats {
    padding: 56px 32px;
    border-top: 1px solid var(--border-strong);
    border-bottom: 1px solid var(--border-strong);
    background: var(--bg-elevated);
  }
  .stats-inner {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }
  .stats-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 18px;
    border: 1px solid var(--gold-bright);
    background: rgba(212,168,67,0.06);
    border-radius: 40px;
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-bright);
    margin-bottom: 36px;
  }
  .stats-badge-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--accent-green);
    box-shadow: 0 0 8px rgba(74,222,128,0.6);
    animation: pulse 2s ease-in-out infinite;
  }

  .live-stats {
    display: inline-flex;
    align-items: center;
    gap: 22px;
    padding: 12px 22px;
    border: 1px solid var(--border-strong);
    background: rgba(14,22,40,0.6);
    border-radius: 999px;
    font-family: 'DM Sans', sans-serif;
    margin-bottom: 18px;
  }
  .live-stats-item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .live-stats-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 24px;
    font-weight: 600;
    color: var(--gold-bright);
    line-height: 1;
    font-variant-numeric: tabular-nums;
    transition: color var(--transition);
  }
  .live-stats-num.flash { color: var(--gold); }
  .live-stats[data-state="empty"] .live-stats-num { color: var(--text-muted); }
  .live-stats-label {
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }
  .live-stats-sep {
    width: 1px;
    height: 20px;
    background: var(--border-strong);
    opacity: 0.5;
  }
  .live-stats-meta {
    display: block;
    margin-top: 8px;
    text-align: center;
    font-size: 10.5px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  .cumulative-stats {
    display: block;
    margin-top: 14px;
    text-align: center;
    font-size: 13px;
    color: var(--text-cream);
    font-weight: 300;
    letter-spacing: 0.02em;
  }
  .cumulative-stats :global(strong) {
    color: var(--gold-bright);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    transition: color var(--transition);
  }
  .cumulative-stats :global(strong.flash) { color: var(--text-bright); }

  .stats-grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
  }
  .stats-grid > * { min-width: 0; }
  .stat-item { text-align: center; }
  .stat-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 48px;
    font-weight: 700;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 10px;
    font-variant-numeric: lining-nums tabular-nums;
    font-feature-settings: 'lnum' 1, 'tnum' 1;
  }
  .stat-label {
    font-size: 13px;
    font-weight: 300;
    color: var(--text-cream);
    line-height: 1.55;
  }

  @media (max-width: 960px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 580px) {
    #stats { padding: 56px 20px; }
  }
  @media (max-width: 520px) {
    .live-stats { gap: 14px; padding: 10px 16px; }
    .live-stats-num { font-size: 20px; }
  }
</style>
