---
// 첫 방문 1회만 노출되는 브랜드 인트로. sessionStorage gate + reduced-motion respect.
// LCP 회피를 위해 의미 마크업(h1/main 등) 사용 금지 — 순수 div+span 으로만 구성.
const wordmark = ['n', 't', 'a', 'b', 'l', 'e'];
---

<div id="brandSplash" class="brand-splash" aria-hidden="true">
  <div class="brand-splash-bg"></div>
  <div class="brand-splash-inner">
    <div class="brand-splash-mark">
      {wordmark.map((c, i) => (
        <span class="brand-splash-char" style={`--i:${i}`}>{c}</span>
      ))}
    </div>
    <div class="brand-splash-underline">
      <span class="brand-splash-spark left"></span>
      <span class="brand-splash-spark right"></span>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    try {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      if (sessionStorage.getItem('ntable_splash_seen') === '1') return;
      var el = document.getElementById('brandSplash');
      if (!el) return;
      el.classList.add('show');
      document.documentElement.style.overflow = 'hidden';
      var isMobile = window.matchMedia('(max-width: 580px)').matches;
      var showMs = isMobile ? 1800 : 2500;
      setTimeout(function () {
        el.classList.add('hide');
        document.documentElement.style.overflow = '';
        try { sessionStorage.setItem('ntable_splash_seen', '1'); } catch (_) {}
      }, showMs);
      setTimeout(function () {
        el.style.display = 'none';
      }, showMs + 500);
    } catch (_) {}
  })();
</script>

<style>
  .brand-splash {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
    background: var(--bg-deep, #0a0f1e);
    opacity: 1;
    transition: opacity 0.5s ease-out;
    pointer-events: none;
    overflow: hidden;
  }
  .brand-splash.show {
    display: flex;
    pointer-events: auto;
  }
  .brand-splash.hide {
    opacity: 0;
    pointer-events: none;
  }

  /* radial gold bloom behind the wordmark */
  .brand-splash-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse 55% 60% at center,
      rgba(212, 168, 67, 0.16),
      rgba(212, 168, 67, 0.05) 45%,
      transparent 75%
    );
    opacity: 0;
    transform: scale(0.7);
    animation: brandBloom 1.5s 0.15s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
    pointer-events: none;
  }
  @keyframes brandBloom {
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  .brand-splash-inner {
    position: relative;
    text-align: center;
    padding: 0 28px;
  }

  .brand-splash-mark {
    display: inline-block;
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(80px, 11vw, 140px);
    font-weight: 600;
    letter-spacing: 0.05em;
    line-height: 1;
    filter: drop-shadow(0 0 28px rgba(232, 184, 75, 0.22));
  }
  @keyframes brandShimmer {
    0%   { background-position: 0% center; }
    100% { background-position: 220% center; }
  }

  /* bg-clip은 자식 char에 직접 적용 — 부모 bg-clip + 자식 transform 조합은
     stacking context 충돌로 일부 브라우저에서 글자 미렌더 */
  .brand-splash-char {
    display: inline-block;
    opacity: 0;
    filter: blur(14px);
    transform: translateY(22px) scale(0.82);
    background: linear-gradient(
      135deg,
      var(--gold-bright, #e8b84b),
      var(--text-bright, #f5f2ec) 50%,
      var(--gold-bright, #e8b84b)
    );
    background-size: 220% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
    text-shadow: 0 0 24px rgba(232, 184, 75, 0.18);
    animation:
      charReveal 0.85s cubic-bezier(0.2, 0.75, 0.2, 1) forwards,
      brandShimmer 5.5s linear infinite;
    animation-delay: calc(0.15s + var(--i) * 0.09s), 0.7s;
  }
  @keyframes charReveal {
    to {
      opacity: 1;
      filter: blur(0);
      transform: translateY(0) scale(1);
    }
  }

  .brand-splash-underline {
    position: relative;
    width: 72%;
    height: 2px;
    margin: 26px auto 0;
    background: linear-gradient(
      90deg,
      transparent,
      var(--gold-bright, #e8b84b) 28%,
      var(--gold-bright, #e8b84b) 72%,
      transparent
    );
    transform: scaleX(0);
    transform-origin: center;
    opacity: 0;
    box-shadow: 0 0 12px rgba(232, 184, 75, 0.4);
    animation: underlineDraw 0.95s 0.95s cubic-bezier(0.65, 0, 0.35, 1) forwards;
  }
  @keyframes underlineDraw {
    to {
      transform: scaleX(1);
      opacity: 1;
    }
  }

  .brand-splash-spark {
    position: absolute;
    top: 50%;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--gold-bright, #e8b84b);
    box-shadow:
      0 0 10px 3px rgba(232, 184, 75, 0.7),
      0 0 22px 6px rgba(232, 184, 75, 0.35);
    transform: translateY(-50%) scale(0);
    opacity: 0;
    animation: sparkTwinkle 1.1s 1.0s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
  }
  .brand-splash-spark.left  { left: 12%; }
  .brand-splash-spark.right { right: 12%; animation-delay: 1.15s; }

  @keyframes sparkTwinkle {
    0%   { transform: translateY(-50%) scale(0);   opacity: 0; }
    30%  { transform: translateY(-50%) scale(1.7); opacity: 1; }
    60%  { transform: translateY(-50%) scale(0.85); opacity: 0.85; }
    100% { transform: translateY(-50%) scale(1.05); opacity: 0.45; }
  }

  @media (prefers-reduced-motion: reduce) {
    .brand-splash { display: none !important; }
  }
</style>
