---
import type { ContentFor } from '../data/config';
import { renderInlineBreaks } from '../lib/loadContent';
type Props = { data: ContentFor<'problems'> };
const { data } = Astro.props;
const { title } = data;
---

<section id="problem">
  <div class="section-tag reveal">{data.section_tag}</div>
  <h2 class="section-title reveal">
    <Fragment set:html={renderInlineBreaks(title.prefix)} />
    {title.emphasis && <em>{title.emphasis}</em>}
    {title.suffix && <Fragment set:html={renderInlineBreaks(title.suffix)} />}
  </h2>
  <p class="section-body reveal">{data.body}</p>
  <div class="problem-cards reveal">
    {data.cards.map((c) => (
      <div class="problem-card">
        <div class="problem-card-icon">{c.icon}</div>
        <h3>{c.title}</h3>
        <p>{c.body}</p>
        <div class="problem-example">{c.example}</div>
      </div>
    ))}
  </div>
</section>

<style>
  .problem-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 56px;
  }
  .problem-cards > * { min-width: 0; }
  .problem-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    padding: 30px 28px;
    transition: border-color var(--transition), transform var(--transition);
  }
  .problem-card:hover { border-color: var(--border-strong); transform: translateY(-3px); }
  .problem-card-icon { font-size: 26px; margin-bottom: 14px; }
  .problem-card h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 600;
    color: var(--text-bright);
    margin-bottom: 10px;
  }
  .problem-card p {
    font-size: 13px;
    font-weight: 300;
    color: var(--text-muted);
    line-height: 1.8;
  }

  .problem-example {
    margin-top: 14px;
    padding-top: 12px;
    border-top: 1px dashed rgba(212,168,67,0.15);
    font-size: 12px;
    font-style: italic;
    color: var(--gold-bright);
    opacity: 0.82;
    line-height: 1.6;
  }

  @media (max-width: 960px) {
    .problem-cards { grid-template-columns: 1fr; }
  }
</style>
