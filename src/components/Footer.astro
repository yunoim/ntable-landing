---
import type { ContentFor } from '../data/config';
type Props = { data: ContentFor<'footer'> };
const { data } = Astro.props;
---

<footer>
  <div class="footer-inner">
    <div class="footer-logo">
      {data.logo}
      <span class="footer-slogan">{data.slogan}</span>
    </div>
    <div class="footer-info">
      {data.links.map((l, i) => (
        <>
          <a href={l.href}>{l.label}</a>{i < data.links.length - 1 && ' · '}
        </>
      ))}
      <br>
      {data.copyright}
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--bg);
    border-top: 1px solid var(--border-strong);
    padding: 28px 32px;
  }
  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }
  .footer-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 15px;
    font-weight: 600;
    color: var(--gold);
    letter-spacing: 0.06em;
    display: flex;
    flex-direction: column;
    gap: 1px;
    opacity: 0.85;
  }
  .footer-slogan {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px;
    font-weight: 400;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    font-style: italic;
    opacity: 0.85;
  }
  .footer-info {
    font-size: 12px;
    font-weight: 300;
    color: var(--text-bright);
    line-height: 1.8;
    text-align: right;
  }
  .footer-info a {
    color: inherit;
    transition: color var(--transition);
  }
  .footer-info a:hover { color: var(--gold); }

  @media (max-width: 960px) {
    .footer-inner { flex-direction: column; align-items: flex-start; }
    .footer-info { text-align: left; }
  }
</style>
