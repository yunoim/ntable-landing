---
// Conditional Umami analytics script (self-hosted on Railway, proxied via admin.ntable.kr/u/).
// Injected only when both PUBLIC_UMAMI_WEBSITE_ID and PUBLIC_UMAMI_SCRIPT_SRC are set.
//
// Setup:
// - Production: Cloudflare Workers env vars
//   (Dashboard → Workers & Pages → ntable-landing → Settings → Variables)
//     PUBLIC_UMAMI_WEBSITE_ID   — Umami website UUID (Settings → Websites → Edit)
//     PUBLIC_UMAMI_SCRIPT_SRC   — e.g. https://admin.ntable.kr/u/script.js
// - Local dev: .env file with the same vars
// - Either var missing → script not injected, no-op.
//
// Click tracking: any element with [data-umami-event="name"] is auto-tracked
// by the Umami script (no manual delegation needed). When the script is
// absent (env vars missing), clicks simply produce no analytics traffic.
//
// Migration history: 2026-05-09 Plausible → Umami self-hosted (path-proxied
// via admin.ntable.kr/u/* to ad-block-resilient first-party host).

const websiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;
const scriptSrc = import.meta.env.PUBLIC_UMAMI_SCRIPT_SRC;
const enabled = Boolean(websiteId && scriptSrc);
---
{enabled && (
  <script
    is:inline
    defer
    src={scriptSrc}
    data-website-id={websiteId}
  ></script>
)}
