---
import type { ContentFor } from '../data/config';
type Props = { data: ContentFor<'how'> };
const { data } = Astro.props;
---

<section id="how">
  <div class="section-tag reveal">{data.section_tag}</div>
  <h2 class="section-title reveal">{data.title}</h2>
  <p class="section-body reveal">{data.body}</p>

  <div class="roadmap-list reveal" style="margin-top:56px;">
    {data.steps.map((s, i) => (
      <div class="roadmap-item">
        {/* 2026-04-23: phase 텍스트를 index 기반 'Step NN' 로 재계산. yml 의 s.phase 가 폰트/글리프
            이슈로 'Step 00' 처럼 깨져 보이던 문제 방어. DM Sans lining-nums 로 숫자 안전. */}
        <div class="roadmap-phase">
          <span class="roadmap-phase-num">Step {String(i + 1).padStart(2, '0')}</span>
          <span class="roadmap-phase-sub">{s.subphase}</span>
        </div>
        <div class="roadmap-content">
          <div class="roadmap-content-title">{s.title}</div>
          <div class="roadmap-content-body">{s.body}</div>
          <div class="roadmap-tags">
            {s.tags.map((t) => <span class="roadmap-tag">{t}</span>)}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  /* 2026-04-23 (revised): 세로 timeline rail + 원형 dot 완전 제거 (사용자 요청).
     가로 구분선(roadmap-item border-bottom) 과 Step 라벨 강조는 유지.
     phase cell width 150px 도 그대로 — 레이아웃 시프트 없음. */
  .roadmap-list {
    display: flex;
    flex-direction: column;
    --phase-w: 150px;
  }
  .roadmap-item {
    display: grid;
    grid-template-columns: var(--phase-w) 1fr;
    gap: 36px;
    padding: 36px 0;
    border-bottom: 1px solid var(--border-subtle);
    align-items: start;
  }
  .roadmap-item:last-child { border-bottom: none; }

  /* phase cell — 왼쪽 정렬(기본). rail 제거로 중앙 정렬 필요 없음. */
  .roadmap-phase {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: 2px;
  }
  .roadmap-phase-num {
    font-family: 'DM Sans', 'Helvetica Neue', Arial, sans-serif;
    font-size: 22px;
    font-weight: 600;
    color: var(--gold);
    letter-spacing: 0.02em;
    font-variant-numeric: lining-nums tabular-nums;
    font-feature-settings: 'lnum' 1, 'tnum' 1;
    line-height: 1;
  }
  .roadmap-phase-sub {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    font-weight: 400;
  }
  .roadmap-content-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 21px;
    font-weight: 600;
    color: var(--text-bright);
    margin-bottom: 10px;
    line-height: 1.3;
  }
  .roadmap-content-body {
    font-size: 14px;
    font-weight: 300;
    color: var(--text-highlight);
    line-height: 1.85;
    margin-bottom: 16px;
  }
  .roadmap-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .roadmap-tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.05em;
    padding: 4px 12px;
    border: 1px solid var(--border-strong);
    border-radius: 40px;
    color: var(--gold);
    background: rgba(232,184,75,0.18);
  }

  @media (max-width: 960px) {
    /* 태블릿: phase cell 을 상단 배지로 (한 줄). */
    .roadmap-item { grid-template-columns: 1fr; gap: 10px; }
    .roadmap-phase { flex-direction: row; gap: 10px; align-items: baseline; }
  }
  @media (max-width: 768px) {
    /* 모바일: padding 축소. */
    .roadmap-item { padding: 26px 0; }
  }
</style>
