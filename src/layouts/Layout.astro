---
import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/animations.css';
import '../styles/sections.css';
import { loadContent } from '../lib/loadContent';
import AnalyticsScript from '../components/AnalyticsScript.astro';

export interface Props {
  locale?: string;
  htmlLang?: string;
  pageTitle?: string;
  pageDescription?: string;
}

const { locale = 'ko', htmlLang, pageTitle, pageDescription } = Astro.props;
const meta = loadContent('meta', locale);
const title = pageTitle ?? meta.title;
const description = pageDescription ?? meta.description;
const lang = htmlLang ?? meta.lang;
const isEnFallback = locale === 'en';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: meta.organization.name,
  slogan: meta.organization.slogan,
  url: meta.organization.url,
  logo: meta.organization.logo,
  email: meta.organization.email,
  description: meta.organization.description,
  sameAs: meta.organization.same_as,
};

const faviconSvg = `data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='20' fill='%230a0f1e'/%3E%3Ctext x='50' y='72' font-size='68' text-anchor='middle' font-family='Cormorant Garamond, serif' font-weight='700' fill='%23d4a843'%3En%3C/text%3E%3C/svg%3E`;

const fontsHref = 'https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600&family=DM+Sans:wght@400;500;600;700&display=swap';
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="dark" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={meta.canonical} />
  {isEnFallback && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:type" content={meta.og.type} />
  <meta property="og:url" content={meta.og.url} />
  <meta property="og:title" content={meta.og.title} />
  <meta property="og:description" content={meta.og.description} />
  <meta property="og:image" content={meta.og.image} />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:width" content={String(meta.og.image_width)} />
  <meta property="og:image:height" content={String(meta.og.image_height)} />
  <meta property="og:site_name" content={meta.og.site_name} />
  <meta property="og:locale" content={meta.locale} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content={meta.twitter.card} />
  <meta name="twitter:title" content={meta.twitter.title} />
  <meta name="twitter:description" content={meta.twitter.description} />
  <meta name="twitter:image" content={meta.twitter.image} />

  <!-- Favicon (inline SVG) -->
  <link rel="icon" type="image/svg+xml" href={faviconSvg} />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta name="theme-color" content="#0a0f1e" />
  <meta name="msapplication-TileColor" content="#0a0f1e" />

  <!-- JSON-LD Organization -->
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline></script>

  <!-- JSON-LD WebSite -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "ntable",
      "alternateName": "엔테이블",
      "url": "https://ntable.kr",
      "description": "누구나 모임장이 된다. 아이스브레이킹·대화·매칭·결과 정리까지 앱이 진행을 맡는 소셜 모임 진행 도우미.",
      "inLanguage": "ko-KR",
      "publisher": {
        "@type": "Organization",
        "name": "ntable",
        "url": "https://ntable.kr"
      }
    }
  </script>

  <!-- JSON-LD SoftwareApplication -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "ntable",
      "applicationCategory": "SocialNetworkingApplication",
      "operatingSystem": "Web",
      "url": "https://app.ntable.kr",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "KRW" },
      "description": "누구나 모임장이 된다. 회원가입·결제정보·앱 설치 없이 QR 하나로 시작되는 모임 진행 도우미."
    }
  </script>

  <!-- JSON-LD FAQPage -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "누구나 모임장이 될 수 있나요?",
          "acceptedAnswer": { "@type": "Answer", "text": "네, 누구나 가능합니다. 회원가입 없이 app.ntable.kr에 접속해서 모임 유형을 고르고 바로 QR을 받으세요." }
        },
        {
          "@type": "Question",
          "name": "참가자는 어떻게 들어오나요?",
          "acceptedAnswer": { "@type": "Answer", "text": "모임장이 만든 QR 또는 링크, 또는 6자리 참여 코드로 앱 설치·회원가입 없이 입장합니다." }
        },
        {
          "@type": "Question",
          "name": "참가비는 어떻게 받나요?",
          "acceptedAnswer": { "@type": "Answer", "text": "ntable은 참가비를 일체 받지 않습니다. 모임장이 직접 정해 직접 받는 구조입니다." }
        }
      ]
    }
  </script>

  <!-- Fonts (비동기 로드로 FCP/LCP 차단 회피 — splash가 1.8s 가려서 FOUT 안 보임) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href={fontsHref} onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link rel="stylesheet" href={fontsHref} /></noscript>

  <AnalyticsScript />

  <slot name="head" />
</head>
<body>
  <slot />

  <script>
    // Scroll reveal
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
  </script>
</body>
</html>
