---
import '../styles/tokens.css';

export interface Props {
  title: string;
  htmlLang?: string;
}

const { title, htmlLang = 'ko' } = Astro.props;

const fontsHref = 'https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Noto+Serif+KR:wght@300;400&family=DM+Sans:wght@300;400;500&display=swap';
---
<!DOCTYPE html>
<html lang={htmlLang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="only dark" />
  <title>{title} — ntable</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href={fontsHref} rel="stylesheet" />
</head>
<body>
  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo">ntable</a>
      <a href="/" class="nav-cta-primary">홈으로</a>
    </div>
  </nav>

  <div class="container">
    <slot />
  </div>

  <footer>
    <div class="footer-inner">
      <div class="footer-logo">
        ntable
        <span class="footer-slogan">More Life. People Connect.</span>
      </div>
      <div class="footer-info">
        <a href="/privacy.html">개인정보처리방침</a> ·
        <a href="/terms.html">이용약관</a><br>
        © 2026 ntable · More Life. People Connect.
      </div>
    </div>
  </footer>
</body>
</html>

<style is:global>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  :root { color-scheme: only dark; }
  html { color-scheme: only dark; forced-color-adjust: none; -webkit-text-size-adjust: 100%; }
  input, textarea, select, button { color-scheme: only dark; forced-color-adjust: none; }
  @media (prefers-color-scheme: light) { html { color-scheme: only dark !important; } }
  body {
    background: var(--bg);
    color: var(--text-bright);
    font-family: 'Noto Serif KR', serif;
    font-weight: 300;
    line-height: 1.9;
  }
  body::before {
    content: '';
    position: fixed; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 1000;
    opacity: 0.4;
  }

  /* Nav — same as main site */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(14,22,40,0.97);
    border-bottom: 1px solid var(--border-strong);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .nav-inner {
    max-width: 1100px; margin: 0 auto; padding: 0 32px;
    height: 62px; display: flex; align-items: center; justify-content: space-between;
  }
  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px; font-weight: 600;
    color: var(--gold); letter-spacing: 0.08em;
    text-decoration: none;
  }
  .nav-cta-primary {
    font-size: 13px; font-weight: 700; padding: 8px 20px;
    background: var(--gold-bright); color: var(--bg-deep);
    border-radius: 40px; text-decoration: none;
    box-shadow: 0 2px 12px rgba(212,168,67,0.4);
    transition: transform var(--transition), box-shadow var(--transition);
  }
  .nav-cta-primary:hover { transform: translateY(-1px); box-shadow: 0 4px 18px rgba(212,168,67,0.55); }

  /* Page container */
  .container {
    max-width: 780px; margin: 0 auto;
    padding: 140px 40px 100px;
  }

  /* Page tag */
  .page-tag {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px; letter-spacing: 0.4em;
    color: var(--gold); text-transform: uppercase;
    margin-bottom: 20px;
    display: flex; align-items: center; gap: 12px;
  }
  .page-tag::before {
    content: '';
    width: 24px; height: 1px; background: var(--gold);
  }

  /* H1 */
  h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(36px,5vw,56px);
    font-weight: 300; line-height: 1.15;
    margin-bottom: 12px;
  }
  .effective-date {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px; letter-spacing: 0.1em;
    color: #e8e8e8; margin-bottom: 60px;
  }

  /* TOC */
  .toc {
    background: var(--bg-elevated);
    border: 1px solid rgba(255,255,255,0.22);
    border-left: 3px solid var(--gold);
    padding: 32px 36px;
    border-radius: 4px;
    margin-bottom: 60px;
  }
  .toc-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px; letter-spacing: 0.25em;
    color: var(--gold); text-transform: uppercase;
    margin-bottom: 16px;
  }
  .toc ol {
    list-style: decimal; padding-left: 20px;
  }
  .toc li { margin-bottom: 8px; }
  .toc a {
    color: #e8e8e8; text-decoration: none;
    font-size: 14px; font-family: 'DM Sans', sans-serif;
    font-weight: 300; transition: color 0.3s;
  }
  .toc a:hover { color: var(--gold); }

  /* Legal body content (rendered from marked) */
  .legal-body h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 24px; font-weight: 400;
    color: var(--gold-bright); margin-bottom: 20px;
    margin-top: 56px;
    padding-top: 56px;
    border-top: 1px solid rgba(255,255,255,0.22);
    display: flex; align-items: center; gap: 16px;
  }
  .legal-body h2:first-child {
    border-top: none;
    margin-top: 0;
    padding-top: 0;
  }
  .legal-body h2::before {
    content: attr(data-num);
    font-size: 12px; font-family: 'DM Sans', sans-serif;
    font-weight: 300; color: var(--gold);
    border: 1px solid rgba(201,168,76,0.3);
    padding: 2px 8px; border-radius: 2px;
    letter-spacing: 0.1em;
  }
  .legal-body p {
    font-size: 15px; color: #e8e8e8; margin-bottom: 16px;
  }
  .legal-body ul,
  .legal-body ol {
    padding-left: 24px; margin-bottom: 16px;
  }
  .legal-body li {
    font-size: 15px; color: #e8e8e8; margin-bottom: 8px;
  }
  .legal-body strong { color: var(--text-bright); }
  .legal-body .highlight-box {
    background: var(--bg-elevated);
    border: 1px solid rgba(255,255,255,0.22);
    padding: 24px 28px; border-radius: 4px;
    margin: 24px 0;
  }
  .legal-body .highlight-box p:last-child { margin-bottom: 0; }
  .legal-body table {
    width: 100%; border-collapse: collapse;
    margin: 24px 0; font-size: 14px;
  }
  .legal-body th {
    background: var(--bg-elevated);
    color: var(--gold);
    font-family: 'DM Sans', sans-serif;
    font-weight: 400; font-size: 11px;
    letter-spacing: 0.15em; text-transform: uppercase;
    padding: 14px 16px; text-align: left;
    border-bottom: 1px solid rgba(201,168,76,0.2);
  }
  .legal-body td {
    padding: 14px 16px; color: #e8e8e8;
    border-bottom: 1px solid rgba(255,255,255,0.22);
    vertical-align: top;
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
  }
  .legal-body tr:last-child td { border-bottom: none; }
  .legal-body a {
    color: var(--gold-bright);
    text-decoration: none;
    border-bottom: 1px solid rgba(212,168,67,0.3);
    transition: color 0.3s, border-color 0.3s;
  }
  .legal-body a:hover { color: var(--gold); border-color: var(--gold); }

  /* Footer — same as main */
  footer {
    background: var(--bg);
    border-top: 1px solid var(--border-strong);
    padding: 28px 32px;
  }
  .footer-inner {
    max-width: 1100px; margin: 0 auto;
    display: flex; align-items: center; justify-content: space-between;
    gap: 20px; flex-wrap: wrap;
  }
  .footer-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 15px; font-weight: 600;
    color: var(--gold); letter-spacing: 0.06em;
    display: flex; flex-direction: column; gap: 1px;
    opacity: 0.85;
    text-decoration: none;
  }
  .footer-slogan {
    font-family: 'DM Sans', sans-serif; font-size: 10px;
    font-weight: 400; color: var(--text-muted);
    letter-spacing: 0.06em; font-style: italic;
    opacity: 0.85;
  }
  .footer-info {
    font-size: 12px; font-weight: 300;
    color: var(--text-bright);
    line-height: 1.8; text-align: right;
  }
  .footer-info a {
    color: inherit; text-decoration: none;
    transition: color 0.3s;
  }
  .footer-info a:hover { color: var(--gold); }

  @media (max-width: 768px) {
    .nav-inner { padding: 0 20px; }
    .container { padding: 120px 24px 80px; }
    footer { padding: 24px 20px; }
    .footer-inner { flex-direction: column; align-items: flex-start; }
    .footer-info { text-align: left; }
  }
</style>
