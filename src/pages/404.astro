---
import Layout from '../layouts/Layout.astro';
---

<Layout pageTitle="404 — 이 주소엔 모임이 없어요 | ntable" pageDescription="찾으시는 페이지를 찾을 수 없어요. 메인으로 돌아가 모임을 시작해 보세요.">
  <Fragment slot="head">
    <meta name="robots" content="noindex" />
  </Fragment>

  <main class="not-found">
    <p class="nf-eyebrow">PAGE NOT FOUND</p>
    <div class="nf-code" aria-hidden="true">404</div>
    <p class="nf-message">이 주소엔 <em>모임이 없어요.</em><br />다른 곳에서 만나요.</p>
    <div class="nf-actions">
      <a href="/" class="nf-cta primary" data-event="404_back_home">→ 메인으로 돌아가기</a>
      <a href="https://app.ntable.kr" class="nf-cta ghost" data-event="404_open_app">바로 모임 열기</a>
    </div>
  </main>
</Layout>

<style>
  .not-found {
    min-height: 78vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 100px 32px 80px;
    text-align: center;
    gap: 24px;
  }
  .nf-eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--gold);
    text-transform: uppercase;
    margin: 0;
  }
  .nf-code {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(120px, 22vw, 220px);
    font-weight: 700;
    line-height: 0.95;
    background: linear-gradient(135deg, var(--gold-bright), var(--gold), var(--gold-bright));
    background-size: 220% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
    margin: 0;
    filter: drop-shadow(0 0 24px rgba(232, 184, 75, 0.18));
    animation: shimmer 5s linear infinite;
  }
  @keyframes shimmer {
    0%   { background-position: 0% center; }
    100% { background-position: 220% center; }
  }
  .nf-message {
    font-size: 17px;
    color: var(--text-highlight);
    line-height: 1.7;
    max-width: 460px;
    margin: 0;
  }
  .nf-message em {
    font-style: italic;
    color: var(--gold-bright);
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.18em;
  }
  .nf-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 8px;
  }
  .nf-cta {
    display: inline-flex;
    align-items: center;
    padding: 13px 28px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.04em;
    border-radius: 40px;
    transition: background var(--transition), border-color var(--transition), transform var(--transition);
  }
  .nf-cta.primary {
    background: var(--gold-bright);
    color: var(--bg-deep);
    box-shadow: 0 4px 18px rgba(212, 168, 67, 0.4);
  }
  .nf-cta.primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 26px rgba(212, 168, 67, 0.55);
  }
  .nf-cta.ghost {
    border: 1.5px solid var(--gold);
    color: var(--gold-bright);
  }
  .nf-cta.ghost:hover {
    background: rgba(232, 184, 75, 0.15);
    border-color: var(--gold-bright);
  }
</style>
